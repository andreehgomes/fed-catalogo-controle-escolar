{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "account": {
      ".indexOn": ["uid"]
    },
    "campaigns": {
      ".indexOn": ["nome", "nomeLower", "status", "dataCriacao"]
    },
    "clients": {
      ".indexOn": ["nomeLower"]
    },
    "sales": {
      ".indexOn": ["campaignKey", "clienteKey", "clienteNomeLower", "dataCriacao", "status"]
    },
    "expenses": {
      ".indexOn": ["campaignKey", "data", "dataCriacao"]
    }
  }
}
