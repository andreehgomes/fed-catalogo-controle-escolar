    "@angular/localize": "^20.3.3",
    "@types/html2canvas": "^0.5.35",
    "@types/jasmine": "~5.1.0",
    "codelyzer": "^6.0.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
